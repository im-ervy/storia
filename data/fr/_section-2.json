    { "text": "courir vite", "translatedText": "correr rápido", "explanation": null } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "et elle a été bientôt", "newLine": false, "translation": { "text": "e ela logo estava", "tips": [
    { "text": "a été", "translatedText": "esteve / ficou", "explanation": null },
    { "text": "bientôt", "translatedText": "logo / em breve", "explanation": null } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "à côté de lui", "newLine": false, "translation": { "text": "ao lado dele", "tips": [
    { "text": "à côté de", "translatedText": "ao lado de", "explanation": null },
    { "text": "lui", "translatedText": "ele", "explanation": "Depois de preposição, usa-se \"lui\" para \"ele\": \"de lui\" = \"dele\"." } ] } },
  { "text": ".", "newLine": false, "translation": null },

  { "text": "« ", "newLine": true, "translation": null },
  { "text": "C'est quoi", "newLine": false, "translation": { "text": "Qual é", "tips": [
