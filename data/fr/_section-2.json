  { "text": ". ", "newLine": false, "translation": null },
  { "text": "Il ne savait pas", "newLine": false, "translation": { "text": "Ele não sabia", "tips": [] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "que la femme était une fée", "newLine": false, "translation": { "text": "que a mulher era uma fada", "tips": [
    { "text": "était", "translatedText": "era", "explanation": null },
    { "text": "une fée", "translatedText": "uma fada", "explanation": null } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "et qu'elle pouvait faire", "newLine": false, "translation": { "text": "e que ela podia fazer", "tips": [] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "des choses comme ça", "newLine": false, "translation": { "text": "coisas assim", "tips": [
    { "text": "des choses", "translatedText": "coisas", "explanation": null },
    { "text": "comme ça", "translatedText": "como essa / assim", "explanation": "\"comme ça\" é literalmente \"como isso\" e significa \"assim, desse jeito\"." } ] } },
  { "text": ".", "newLine": false, "translation": null },

  { "text": "Elle a dit", "newLine": true, "translation": { "text": "Ela disse", "tips": [] } },
  { "text": " : « ", "newLine": false, "translation": null },
  { "text": "Tu m'as fait", "newLine": false, "translation": { "text": "Você me fez", "tips": [
    { "text": "Tu", "translatedText": "Você", "explanation": null },
    { "text": "m'as fait", "translatedText": "me fez", "explanation": null } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "quelque chose de très mal", "newLine": false, "translation": { "text": "algo muito ruim", "tips": [
    { "text": "quelque chose", "translatedText": "alguma coisa", "explanation": null },
    { "text": "de très mal", "translatedText": "de muito ruim", "explanation": "Depois de \"quelque chose\", o francês usa \"de\" antes do adjetivo: \"quelque chose de mal\" = \"algo (de) ruim\"." } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "hier", "newLine": false, "translation": { "text": "ontem", "tips": [] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "et j'ai entendu dire", "newLine": false, "translation": { "text": "e ouvi dizer", "tips": [
    { "text": "j'ai entendu", "translatedText": "eu ouvi", "explanation": null },
    { "text": "dire", "translatedText": "dizer", "explanation": "\"entendre dire que...\" é uma expressão fixa: \"ouvir dizer que...\"." } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "que ce n'était pas", "newLine": false, "translation": { "text": "que não era", "tips": [] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "la première fois", "newLine": false, "translation": { "text": "a primeira vez", "tips": [] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "que tu mentais", "newLine": false, "translation": { "text": "que você mentia", "tips": [
    { "text": "tu mentais", "translatedText": "você mentia", "explanation": "\"mentais\" é o imperfeito de \"mentir\". O imperfeito indica algo habitual no passado: \"você costumava mentir\"." } ] } },
  { "text": ". ", "newLine": false, "translation": null },
  { "text": "Alors maintenant", "newLine": false, "translation": { "text": "Então agora", "tips": [] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "je vais te montrer", "newLine": false, "translation": { "text": "eu vou te mostrar", "tips": [
