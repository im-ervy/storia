    { "text": "a dit", "translatedText": "disse", "explanation": null } ] } },
  { "text": " : « ", "newLine": false, "translation": null },
  { "text": "Tu m'entends", "newLine": false, "translation": { "text": "Você está me ouvindo", "tips": [
    { "text": "Tu", "translatedText": "Você", "explanation": "\"Tu\" é o \"você\" informal francês. O verbo na 2ª pessoa muitas vezes acompanha o \"-s\" no fim (\"entends\")." },
    { "text": "m'entends", "translatedText": "me ouve", "explanation": null } ] } },
  { "text": ", ", "newLine": false, "translation": null },
