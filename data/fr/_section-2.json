  { "text": " ? ", "newLine": false, "translation": null },
  { "text": "Pourquoi tu t'enfuis", "newLine": false, "translation": { "text": "Por que você está fugindo", "tips": [
    { "text": "Pourquoi", "translatedText": "Por que", "explanation": null },
    { "text": "tu t'enfuis", "translatedText": "você foge", "explanation": "Novamente o reflexivo \"s'enfuir\". Conjugado com \"tu\", o \"se\" vira \"te\" e, antes de vogal, \"t'\": \"tu t'enfuis\" = \"você foge\"." } ] } },
  { "text": " ? » ", "newLine": false, "translation": null },
  { "text": "elle a dit", "newLine": false, "translation": { "text": "ela disse", "tips": [] } },
