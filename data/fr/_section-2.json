    { "text": "très peur", "translatedText": "muito medo", "explanation": "Em francês o medo se \"tem\": \"avoir peur\" = \"ter medo\". Por isso \"avait très peur\" = \"estava com muito medo\"." } ] } },
  { "text": ".", "newLine": false, "translation": null },

  { "text": "« ", "newLine": true, "translation": null },
  { "text": "Arrête", "newLine": false, "translation": { "text": "Pare", "tips": [] } },
