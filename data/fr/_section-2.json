[
  { "text": "Grande Bouche a senti", "newLine": true, "translation": { "text": "Grande Bouche sentiu", "tips": [
    { "text": "a senti", "translatedText": "sentiu", "explanation": "\"a senti\" é o passé composé do verbo \"sentir\". Em francês usa-se o auxiliar \"avoir\" (ter) + particípio, mas em português traduzimos pelo pretérito perfeito simples: \"sentiu\"." } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "une douleur", "newLine": false, "translation": { "text": "uma dor", "tips": [] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "dans son cœur", "newLine": false, "translation": { "text": "no seu coração", "tips": [
    { "text": "dans", "translatedText": "dentro de / em", "explanation": null },
    { "text": "son cœur", "translatedText": "seu coração", "explanation": "\"son\" significa \"seu/sua\" e concorda com o gênero da COISA possuída, não do dono. Como \"cœur\" é masculino, usa-se \"son\"." } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "dès qu'il l'a vue", "newLine": false, "translation": { "text": "assim que a viu", "tips": [
    { "text": "dès qu'", "translatedText": "assim que", "explanation": "\"dès que\" é uma expressão que significa \"assim que / no momento em que\". Diante de vogal vira \"dès qu'\"." },
    { "text": "il l'a vue", "translatedText": "ele a viu", "explanation": "\"l'\" é o pronome \"la\" (a ela) encurtado antes da vogal. Repare que o particípio recebe um \"-e\" extra (\"vue\") para concordar com esse objeto feminino que vem antes." } ] } },
  { "text": " — ", "newLine": false, "translation": null },
  { "text": "c'était du remords", "newLine": false, "translation": { "text": "era remorso", "tips": [
    { "text": "c'était", "translatedText": "isso era", "explanation": null },
    { "text": "du remords", "translatedText": "(do) remorso", "explanation": "\"du\" aqui é o artigo partitivo, que indica uma quantidade indefinida de algo. Em português ele simplesmente desaparece: \"era remorso\"." } ] } },
  { "text": " —, ", "newLine": false, "translation": null },
  { "text": "mais il ne savait pas", "newLine": false, "translation": { "text": "mas ele não sabia", "tips": [
    { "text": "ne savait pas", "translatedText": "não sabia", "explanation": "A negação em francês é dupla: \"ne ... pas\" envolve o verbo. \"savait\" é o imperfeito de \"savoir\" (saber)." } ] } },
  { "text": " ", "newLine": false, "translation": null },
