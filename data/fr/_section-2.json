  { "text": ", ", "newLine": false, "translation": null },
  { "text": "il ne pouvait", "newLine": false, "translation": { "text": "ele não conseguia", "tips": [] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "tout simplement pas", "newLine": false, "translation": { "text": "simplesmente não", "tips": [
