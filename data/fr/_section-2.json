    { "text": "alors", "translatedText": "então", "explanation": null },
    { "text": "il n'a rien fait", "translatedText": "ele não fez nada", "explanation": "\"ne ... rien\" significa \"nada\". Aqui o \"ne\" vira \"n'\" antes da vogal: \"il n'a rien fait\" = \"ele não fez nada\"." } ] } },
  { "text": ".", "newLine": false, "translation": null },

  { "text": "Puis", "newLine": true, "translation": { "text": "Depois", "tips": [] } },
  { "text": ", ", "newLine": false, "translation": null },
