    { "text": "lui a demandé", "translatedText": "perguntou a ele", "explanation": "\"lui\" aqui significa \"a ele/a ela\" (objeto indireto): \"lui a demandé\" = \"perguntou a ele\"." } ] } },
  { "text": " : « ", "newLine": false, "translation": null },
