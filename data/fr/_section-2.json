    { "text": "vas-tu", "translatedText": "vai você", "explanation": "\"Comment vas-tu ?\" é literalmente \"Como vais tu?\", a forma padrão de perguntar \"Como você está?\". Repare na inversão verbo-sujeito (\"vas-tu\") típica das perguntas." } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "aujourd'hui", "newLine": false, "translation": { "text": "hoje", "tips": [] } },
  { "text": " ? ", "newLine": false, "translation": null },
  { "text": "Viens ici", "newLine": false, "translation": { "text": "Venha aqui", "tips": [] } },
