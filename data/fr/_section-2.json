  { "text": " ! »", "newLine": false, "translation": null },

  { "text": "Grande Bouche a alors décidé", "newLine": true, "translation": { "text": "Grande Bouche então decidiu", "tips": [
    { "text": "a alors décidé", "translatedText": "então decidiu", "explanation": "Repare que o advérbio \"alors\" (então) entrou no meio do passé composé, entre o auxiliar \"a\" e o particípio \"décidé\"." } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "que la meilleure chose à faire", "newLine": false, "translation": { "text": "que a melhor coisa a fazer", "tips": [
    { "text": "la meilleure chose", "translatedText": "a melhor coisa", "explanation": "\"meilleure\" é o superlativo de \"bonne\" (boa) e equivale a \"melhor\"; o \"-e\" final concorda com \"chose\", que é feminino." },
    { "text": "à faire", "translatedText": "a (ser) feita / a fazer", "explanation": null } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "était de s'enfuir", "newLine": false, "translation": { "text": "era fugir", "tips": [
    { "text": "était", "translatedText": "era", "explanation": null },
    { "text": "s'enfuir", "translatedText": "fugir (-se)", "explanation": "\"s'enfuir\" é um verbo reflexivo (o \"se\" faz parte dele). Em português dizemos só \"fugir\", sem o pronome." } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "et c'est ce qu'il a fait", "newLine": false, "translation": { "text": "e foi o que ele fez", "tips": [
    { "text": "c'est ce qu'", "translatedText": "é isso o que", "explanation": "\"ce que\" significa \"o que / aquilo que\". A construção \"c'est ce que...\" enfatiza: \"é justamente o que...\"." },
    { "text": "il a fait", "translatedText": "ele fez", "explanation": null } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "mais la femme aussi", "newLine": false, "translation": { "text": "mas a mulher também", "tips": [] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "pouvait courir vite", "newLine": false, "translation": { "text": "conseguia correr rápido", "tips": [
