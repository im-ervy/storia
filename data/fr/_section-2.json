    { "text": "te montrer", "translatedText": "te mostrar", "explanation": null } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "que la vérité", "newLine": false, "translation": { "text": "que a verdade", "tips": [] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "est toujours meilleure", "newLine": false, "translation": { "text": "é sempre melhor", "tips": [
    { "text": "toujours", "translatedText": "sempre", "explanation": null },
    { "text": "meilleure", "translatedText": "melhor", "explanation": null } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "et à partir de ce moment", "newLine": false, "translation": { "text": "e a partir deste momento", "tips": [
    { "text": "à partir de", "translatedText": "a partir de", "explanation": null },
    { "text": "ce moment", "translatedText": "este momento", "explanation": null } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "tu ne pourras dire la vérité", "newLine": false, "translation": { "text": "você não poderá dizer a verdade", "tips": [
    { "text": "tu ne pourras", "translatedText": "você não poderá", "explanation": "\"pourras\" é o futuro de \"pouvoir\" (poder): \"tu pourras\" = \"você poderá\"." },
    { "text": "dire la vérité", "translatedText": "dizer a verdade", "explanation": null } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "à personne", "newLine": false, "translation": { "text": "a ninguém", "tips": [
    { "text": "à personne", "translatedText": "a ninguém", "explanation": "\"personne\", junto da negação, significa \"ninguém\". \"à personne\" = \"a ninguém\"." } ] } },
  { "text": ". »", "newLine": false, "translation": null },

  { "text": "Puis elle est partie", "newLine": true, "translation": { "text": "Depois ela foi embora", "tips": [
    { "text": "Puis", "translatedText": "Depois", "explanation": null },
    { "text": "elle est partie", "translatedText": "ela partiu / foi embora", "explanation": "Alguns verbos de movimento, como \"partir\", formam o passé composé com \"être\" (ser/estar), não com \"avoir\". Por isso o particípio concorda com o sujeito feminino: \"partie\" com \"-e\"." } ] } },
  { "text": ".", "newLine": false, "translation": null },

  { "text": "À ce moment-là", "newLine": true, "translation": { "text": "Naquele momento", "tips": [
    { "text": "ce moment-là", "translatedText": "aquele momento", "explanation": "O \"-là\" colado ao substantivo indica distância (\"aquele\"), em oposição a \"-ci\" (\"este\")." } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "Grande Bouche jouait au ballon", "newLine": false, "translation": { "text": "Grande Bouche jogava bola", "tips": [
    { "text": "jouait", "translatedText": "jogava", "explanation": null },
    { "text": "au ballon", "translatedText": "com a bola", "explanation": "\"jouer au ballon\" = \"jogar bola\". Com jogos e esportes usa-se \"jouer à\" (\"au\" = \"à + le\")." } ] } },
  { "text": " ", "newLine": false, "translation": null },
  { "text": "depuis longtemps", "newLine": false, "translation": { "text": "havia muito tempo", "tips": [
    { "text": "depuis", "translatedText": "desde / há", "explanation": "\"depuis\" indica desde quando algo acontece. \"depuis longtemps\" = \"há muito tempo\"." },
    { "text": "longtemps", "translatedText": "muito tempo", "explanation": null } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "et il avait faim", "newLine": false, "translation": { "text": "e estava com fome", "tips": [
    { "text": "avait faim", "translatedText": "tinha fome", "explanation": "Assim como o medo, a fome se \"tem\" em francês: \"avoir faim\" = \"estar com fome\"." } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "alors il est rentré à la maison", "newLine": false, "translation": { "text": "então voltou para casa", "tips": [
    { "text": "il est rentré", "translatedText": "ele voltou", "explanation": "\"rentrer\" (voltar para casa) também usa \"être\" no passé composé: \"il est rentré\"." },
    { "text": "à la maison", "translatedText": "para casa", "explanation": null } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "et quand sa mère l'a vu", "newLine": false, "translation": { "text": "e quando sua mãe o viu", "tips": [
    { "text": "sa mère", "translatedText": "sua mãe", "explanation": null },
    { "text": "l'a vu", "translatedText": "o viu", "explanation": null } ] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "elle a demandé", "newLine": false, "translation": { "text": "ela perguntou", "tips": [
    { "text": "a demandé", "translatedText": "perguntou", "explanation": "Cuidado com o falso amigo: \"demander\" significa \"perguntar/pedir\", e NÃO \"demandar\"." } ] } },
  { "text": " : « ", "newLine": false, "translation": null },
  { "text": "Mon fils", "newLine": false, "translation": { "text": "Meu filho", "tips": [] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "tu veux manger quelque chose", "newLine": false, "translation": { "text": "você quer comer alguma coisa", "tips": [
    { "text": "tu veux", "translatedText": "você quer", "explanation": null },
    { "text": "manger quelque chose", "translatedText": "comer alguma coisa", "explanation": null } ] } },
  { "text": " ? »", "newLine": false, "translation": null },

  { "text": "Pourtant", "newLine": true, "translation": { "text": "No entanto", "tips": [
    { "text": "Pourtant", "translatedText": "No entanto / contudo", "explanation": "Não confunda \"pourtant\" (no entanto) com \"pour tant\". Sozinho, \"pourtant\" indica contraste." } ] } },
  { "text": ", ", "newLine": false, "translation": null },
