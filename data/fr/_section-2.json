  { "text": "la femme a dit", "newLine": false, "translation": { "text": "a mulher disse", "tips": [] } },
  { "text": ", ", "newLine": false, "translation": null },
  { "text": "et à ce moment précis", "newLine": false, "translation": { "text": "e naquele exato momento", "tips": [
