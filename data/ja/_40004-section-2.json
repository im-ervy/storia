ation":{"text":"Anna ga — a Anna","tips":[{"text":"アンナ","translatedText":"Anna = Anna","explanation":null},{"text":"が","translatedText":"ga = (sujeito)","explanation":null}]}},{"text":"聞きました","newLine":false,"translation":{"text":"kikimashita — perguntou","tips":[{"text":"聞きました","translatedText":"kikimashita = perguntou","explanation":null}]}},{"text":"。","newLine":false,"translation":null},{"text":"「","newLine":true,"translation":null},{"text":"かいしゃや","newLine":false,"translation":{"text":"kaisha ya — empresas e","tips":[{"text":"かいしゃ","translatedText":"kaisha = empresa (会社)","explanation":"かいしゃ (会社) = \"empresa / firma\". É a palavra de onde vem 会社員 (kaishain, \"funcionário de empresa\"), uma das profissões mais comuns no Japão.","priority":"low"},{"text":"や","translatedText":"ya = e (entre outros)","explanation":null}]}},{"text":"、","newLine":false,"translation":null},{"text":"大学や","newLine":false,"translation":{"text":"daigaku ya — universidades e","tips":[{"text":"大学","translatedText":"daigaku = universidade (大学)","explanation":"大学 (universidade) é literalmente 大 (grande) + 学 (escola/estudo) — ou seja, \"a escola grande / a escola dos adultos\". Compare: 学校 gakkō (escola em geral), 大学 daigaku (universidade). Ótima forma de memorizar pelos kanji.","priority":"high"},{"text":"や","translatedText":"ya = e (entre outros)","explanation":null}]}},{"text":"、","newLine":false,"translation":null},{"text":"はくぶつかんで","newLine":false,"translation":{"text":"hakubutsukan de — em museus","tips":[{"text":"はくぶつかん","translatedText":"hakubutsukan = museu (博物館)","explanation":"はくぶつかん (博物館) = \"museu\". O 〜館 (kan) no fim indica \"prédio/estabelecimento\" e aparece em vários lugares públicos: 図書館 toshokan (biblioteca), 映画館 eigakan (cinema).","priority":"low"},{"text":"で","translatedText":"de = em (lugar da ação)","explanation":"で marca o lugar onde uma AÇÃO acontece (≠ に, que marca onde algo só está). Aqui trabalha-se NESSES lugares, então で: かいしゃや大学やはくぶつかんではたらく = \"trabalhar em empresas, universidades e museus\".","priority":"low"}]}},{"text":"はたらいて","newLine":false,"translation":{"text":"hataraite — trabalhar e","tips":[{"text":"はたらいて","translatedText":"hataraite = trabalhar (forma -te)","explanation":null}]}},{"text":"、","newLine":false,"translation":null},{"text":"世界や","newLine":false,"translation":{"text":"sekai ya — do mundo e","tips":[{"text":"世界","translatedText":"sekai = mundo","explanation":null},{"text":"や","translatedText":"ya = e (entre outros)","explanation":null}]}},{"text":"しぜんや","newLine":false,"translation":{"text":"shizen ya — da natureza e","tips":[{"text":"しぜん","translatedText":"shizen = natureza (自然)","explanation":null},{"text":"や","translatedText":"ya = e (entre outros)","explanation":null}]}},{"text":"うちゅうの","newLine":false,"translation":{"text":"uchū no — do universo","tips":[{"text":"うちゅう","translatedText":"uchū = universo / espaço (宇宙)","explanation":"うちゅう (宇宙) = \"universo / cosmos / espaço sideral\". Note o ū longo (não \"uchu\"). Vocábulo científico bonito para somar à coleção.","priority":"low"},{"text":"の","translatedText":"no = de","explanation":null}]}},{"text":"ことで","newLine":false,"translation":{"text":"koto de — sobre as coisas","tips":[{"text":"こと","translatedText":"koto = coisa","explanation":null},{"text":"で","translatedText":"de = sobre / quanto a","explanation":null}]}},{"text":"、","newLine":false,"translation":null},{"text":"新しい","newLine":false,"translation":{"text":"atarashii — novas","tips":[{"text":"新しい","translatedText":"atarashii = novo","explanation":null}]}},{"text":"ことを","newLine":false,"translation":{"text":"koto o — coisas","tips":[{"text":"こと","translatedText":"koto = coisa","explanation":null},{"text":"を","translatedText":"o = (objeto)","explanation":null}]}},{"text":"見つけようとするの","newLine":false,"translation":{"text":"mitsukeyō to suru no — tentar descobrir","tips":[{"text":"見つけよう","translatedText":"mitsukeyō = vamos achar / achar (volitivo)","explanation":null},{"text":"とする","translatedText":"to suru = tentar","explanation":"〜ようとする = \"tentar fazer / procurar fazer\". Combina o volitivo (見つけよう, \"vamos achar\") com とする. 新しいことを見つけようとする = \"tentar descobrir coisas novas\" — a essência da pesquisa.","priority":"low"},{"text":"の","translatedText":"no = (explicativo)","explanation":null}]}},{"text":"。","newLine":false,"translation":null},{"text":"まだ","newLine":false,"translation":{"text":"mada — ainda","tips":[{"text":"まだ","translatedText":"mada = ainda","explanation":null}]}},{"text":"べんきょうしないと","newLine":false,"translation":{"text":"benkyō shinai to — que precisa estudar","tips":[{"text":"べんきょうしない","translatedText":"benkyō shinai = não estudar","explanation":null},{"text":"と","translatedText":"to = (parte de \"ter que\")","explanation":null}]}},{"text":"いけないことが","newLine":false,"translation":{"text":"ikenai koto ga — coisas a estudar","tips":[{"text":"いけない","translatedText":"ikenai = não pode (deixar de)","explanation":"〜ないといけない = \"ter que\". Aqui dentro de uma frase: べんきょうしないといけないこと = \"coisas que (a gente) tem que estudar / que ainda faltam estudar\".","priority":"low"},{"text":"こと","translatedText":"koto = coisa","explanation":null},{"text":"が","translatedText":"ga = (sujeito)","explanation":null}]}},{"text":"、","newLine":false,"translation":null},{"text":"たくさん","newLine":false,"translation":{"text":"takusan — muitas","tips":[{"text":"たくさん","translatedText":"takusan = muito(s)","explanation":null}]}},{"text":"あるからね","newLine":false,"translation":{"text":"aru kara ne — é que ainda há, sabe","tips":[{"text":"ある","translatedText":"aru = haver (coisa)","explanation":null},{"text":"から","translatedText":"kara = porque / é que","explanation":null},{"text":"ね","translatedText":"ne = sabe / né","explanation":null}]}},{"text":"。","newLine":false,"translation":null},{"text":"」","newLine":false,"translation":null},{"text":"と","newLine":false,"translation":{"text":"to — (citação)","tips":[{"text":"と","translatedText":"to = (citação)","explanation":null}]}},{"text":"お母さんが","newLine":false,"translation":{"text":"okāsan ga — a mãe","tips":[{"text":"お母さん","translatedText":"okāsan = mãe","explanation":null},{"text":"が","translatedText":"ga = (sujeito)","explanation":null}]}},{"text":"せつめいしました","newLine":false,"translation":{"text":"setsumei shimashita — explicou","tips":[{"text":"せつめい","translatedText":"setsumei = explicação (説明)","explanation":"せつめい (説明) = \"explicação\". せつめいする = \"explicar\". Outro verbo do tipo 〜する (substantivo + する vira verbo), como べんきょうする, けんきゅうする, しつもんする.","priority":"low"},{"text":"しました","translatedText":"shimashita = fez","explanation":null}]}},{"text":"。","newLine":false,"translation":null}]