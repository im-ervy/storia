[{"text":"「","newLine":true,"translation":null},{"text":"りかって","newLine":false,"translation":{"text":"rika tte — ciências (\"o tal de ciências\")","tips":[{"text":"りか","translatedText":"rika = ciências (理科)","explanation":"りか (理科) é a matéria escolar \"ciências\". Em japonês escreve-se com os kanji 理科, mas aqui aparece em hiragana porque é texto para iniciantes — é um vocábulo cívico/escolar que vale memorizar.","priority":"low"},{"text":"って","translatedText":"tte = isso de / o tal de","explanation":"って é a forma coloquial de は/というのは: cita o tema da pergunta. 「りかって、何？」 = \"o tal de 'ciências', o que é?\". Bem comum na fala do dia a dia.","priority":"low"}]}},{"text":"、","newLine":false,"translation":null},{"text":"ほんとうは","newLine":false,"translation":{"text":"hontō wa — na verdade","tips":[{"text":"ほんとう","translatedText":"hontō = verdade","explanation":null},{"text":"は","translatedText":"wa = (tópico)","explanation":null}]}},{"text":"何","newLine":false,"translation":{"text":"nani — o que é","tips":[{"text":"何","translatedText":"nani = o que","explanation":null}]}},{"text":"、","newLine":false,"translation":null},{"text":"お母さん","newLine":false,"translation":{"text":"okāsan — mãe","tips":[{"text":"お母さん","translatedText":"okāsan = mãe","explanation":null}]}},{"text":"。","newLine":false,"translation":null},{"text":"」","newLine":false,"translation":null},{"text":"と","newLine":false,"translation":{"text":"to — (citação)","tips":[{"text":"と","translatedText":"to = (marca a fala citada)","explanation":null}]}},{"text":"アンナが","newLine":false,"translation":{"text":"Anna ga — a Anna","tips":[{"text":"アンナ","translatedText":"Anna = Anna (nome próprio)","explanation":"アンナ é o nome da menina, escrito em katakana porque é um nome estrangeiro (Anna). O katakana serve para nomes e palavras vindos de fora.","priority":"low"},{"text":"が","translatedText":"ga = (sujeito)","explanation":null}]}},{"text":"聞きました","newLine":false,"translation":{"text":"kikimashita — perguntou","tips":[{"text